# Root environment file for docker-compose
# Copy this file to .env and fill in real values before running `docker-compose up`.

# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-me-with-a-32-byte-random-secret

# Database credentials — choose your own; do NOT use these defaults in production
POSTGRES_USER=financeuser
POSTGRES_PASSWORD=replace-me-with-a-strong-password
POSTGRES_DB=financedb

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# OpenTelemetry (optional — leave blank to disable telemetry export)
OTEL_EXPORTER_OTLP_ENDPOINT=
VITE_OTEL_ENDPOINT=
